# AI Career Mentor environment configuration

# Optional AI provider. Leave blank to use deterministic rule-based fallback.
# Valid values: openai, gemini, or blank for automatic provider detection.
AI_PROVIDER=

# Optional provider keys. Never commit real secrets.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional model overrides.
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# AI request timeout in seconds. The app falls back to rule-based logic on timeout.
AI_TIMEOUT_SECONDS=12

# SQLite database path.
DATABASE_PATH=database/app.db

# Application log file path.
LOG_PATH=logs/app.log

# Resume PDF upload limit in megabytes.
MAX_PDF_UPLOAD_MB=8
